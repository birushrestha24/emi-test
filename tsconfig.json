{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*":    ["pages/*"],
      "@fixtures/*": ["fixtures/*"],
      "@utils/*":    ["utils/*"],
      "@types-local/*": ["types/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
